# arc-1-lsp configuration — copy to `.env` (gitignored) and edit.
# Precedence: CLI flag > env var > default. Nothing here is required for a bare
# `health` check; a SAP connection needs either the DIRECT block or a BTP
# destination. NEVER commit real secrets — `.env` is gitignored.

# ── adt-ls (BYO — never redistributed; see docs/adr/0002) ─────────────────────
# Explicit path to the adt-ls binary; otherwise auto-discovered from vendor/ or
# an installed `sapse.adt-vscode` extension.
# ARC1_ADT_LS_PATH=/path/to/adt-ls
# Port adt-ls's own MCP server listens on (distinct from VS Code's 2236).
# ARC1_ADT_LS_MCP_PORT=2240

# ── arc-1-lsp's own MCP transport ─────────────────────────────────────────────
ARC1_TRANSPORT=stdio                 # stdio | http-streamable
# ARC1_PORT=8080                     # http-streamable port (CF assigns $PORT)
# API keys for the HTTP edge — comma-separated `key` or `key:label`.
# Empty = auth DISABLED (local dev only). Set at least one for any shared/HTTP use.
# ARC1_API_KEYS=dev-key:local
# ARC1_LOG_LEVEL=info                # error | warn | info | debug

# ── SAP connection: DIRECT mode (internet-reachable backend, e.g. a4h) ─────────
# Set all four to auto-connect a destination at startup. The reverse proxy
# terminates TLS to the backend's HTTPS port.
# ARC1_SAP_HOST=a4h.example.com
# ARC1_SAP_PORT=50001
# ARC1_SAP_USER=DEVELOPER
# ARC1_SAP_PASSWORD=__set_me__       # secret — env only, never commit
# ARC1_SAP_DESTINATION=A4H           # adt-ls destination id (default "SAP")
# ARC1_SAP_CLIENT=001
# ARC1_SAP_LANGUAGE=EN
# ARC1_SAP_INSECURE=true             # accept the backend's self-signed cert

# ── SAP connection: Cloud-Connector mode (on BTP CF, connectivity bound) ──────
# Instead of the DIRECT block, name a BTP destination; the engine resolves it and
# routes adt-ls through the connectivity bridge → Cloud Connector → backend.
# ARC1_SAP_DESTINATION=SAP_TRIAL

# ── Write safety (everything read-only by default) ────────────────────────────
# ARC1_ALLOW_WRITES=false            # enable create/update/activate/delete/generate
# ARC1_ALLOW_TRANSPORT_WRITES=false  # enable create_transport (also needs ALLOW_WRITES)
# ARC1_ALLOWED_PACKAGES=$TMP         # packages writes may target — exact / PREFIX* / *
